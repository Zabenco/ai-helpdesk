# LLM Provider: ollama, openai, anthropic, minimax
LLM_PROVIDER=minimax
LLM_MODEL=MiniMax-Text-01

# API Keys (only needed for non-ollama providers)
MINIMAX_API_KEY=your_minimax_api_key_here
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# MiniMax API Base (usually don't need to change)
MINIMAX_API_BASE=https://api.minimax.chat/v1

# Embedding settings
# Provider: "ollama" (local) or "openai" (works with MiniMax, OpenAI, etc.)
EMBED_PROVIDER=openai
EMBED_MODEL=text-embedding-v03  # MiniMax embedding model, or use "text-embedding-3-small" for OpenAI

# Ollama (only needed if EMBED_PROVIDER=ollama)
EMBED_MODEL_OLLAMA=nomic-embed-text

# Chunking config for document indexing
CHUNK_SIZE=1024
CHUNK_OVERLAP=256

# Chat memory token limit per user
MEMORY_TOKEN_LIMIT=4096
