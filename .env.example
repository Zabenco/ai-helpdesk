# LLM Provider: ollama, openai, anthropic, minimax
LLM_PROVIDER=ollama
LLM_MODEL=llama3

# API Keys
MINIMAX_API_KEY=your_minimax_api_key_here
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# MiniMax API Base (only needed for MiniMax)
MINIMAX_API_BASE=https://api.minimax.chat/v1

# Embedding settings
# Provider: "ollama" (local, recommended) or "openai" (API-based)
EMBED_PROVIDER=ollama
EMBED_MODEL=nomic-embed-text

# Chunking config for document indexing
CHUNK_SIZE=1024
CHUNK_OVERLAP=256

# Chat memory token limit per user
MEMORY_TOKEN_LIMIT=4096
